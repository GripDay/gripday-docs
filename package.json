{
  "name": "@gripday/gripday-docs",
  "version": "0.0.1",
  "description": "Project documentation powered by Vitepress.",
  "type": "module",
  "scripts": {
    "docs:build": "vitepress build docs",
    "docs:dev": "vitepress dev docs",
    "docs:preview": "vitepress preview docs",
    "lint": "pnpm prettier:check",
    "lint:stylelint": "stylelint \"**/*.css\" --aei",
    "node_modules:clear": "rm -rf node_modules",
    "prepare": "husky",
    "prettier:check": "prettier . --check --ignore-unknown",
    "prettier:write": "prettier . --write",
    "release": "release-it --ci"
  },
  "lint-staged": {
    "*": [
      "pnpm prettier:check"
    ],
    "package.json": [
      "sort-package-json"
    ]
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "devDependencies": {
    "@commitlint/cli": "^20.3.1",
    "@commitlint/config-conventional": "^20.3.1",
    "@release-it/conventional-changelog": "^10.0.4",
    "cross-env": "^10.1.0",
    "cz-conventional-changelog": "^3.3.0",
    "dotenv": "^17.2.3",
    "glob": "^13.0.0",
    "husky": "9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "3.8.0",
    "prettier-plugin-packagejson": "2.5.21",
    "release-it": "^19.2.3",
    "release-it-pnpm": "^4.6.6",
    "sort-package-json": "^3.6.0",
    "stylelint": "^16.26.1",
    "stylelint-config-standard-scss": "^16.0.0",
    "vitepress": "^1.6.4",
    "vue": "^3.5.26"
  },
  "packageManager": "pnpm@10.19.0"
}
