{
  "name": "@gripday/gripday-docs",
  "version": "0.0.0",
  "description": "Project documentation powered by Vitepress.",
  "type": "module",
  "scripts": {
    "docs:build": "vitepress build docs",
    "docs:dev": "vitepress dev docs",
    "docs:preview": "vitepress preview docs",
    "formatter:check": "prettier . --check --ignore-unknown",
    "formatter:write": "prettier . --write",
    "lint": "pnpm formatter:check",
    "lint:stylelint": "stylelint \"**/*.css\" --aei",
    "node_modules:cleanup": "rm -rf node_modules",
    "prepare": "husky",
    "release": "release-it --ci"
  },
  "lint-staged": {
    "*": [
      "pnpm formatter:check"
    ],
    "package.json": [
      "sort-package-json"
    ]
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@release-it/conventional-changelog": "^10.0.5",
    "cross-env": "^10.1.0",
    "cz-conventional-changelog": "^3.3.0",
    "dotenv": "^17.3.1",
    "glob": "^13.0.6",
    "husky": "9.1.7",
    "lint-staged": "^16.3.2",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "oxlint-tsgolint": "^0.16.0",
    "prettier": "3.8.1",
    "prettier-plugin-packagejson": "3.0.2",
    "release-it": "^19.2.4",
    "release-it-pnpm": "^4.6.6",
    "sort-package-json": "^3.6.1",
    "stylelint": "^16.26.1",
    "stylelint-config-standard-scss": "^16.0.0",
    "tsdown": "^0.21.1",
    "vitepress": "^1.6.4",
    "vue": "^3.5.30"
  },
  "packageManager": "pnpm@10.30.3"
}
